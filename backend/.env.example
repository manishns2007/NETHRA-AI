# NETHRA AI Backend Environment Variables

# Core Configuration
PROJECT_NAME="NETHRA AI"
API_V1_STR="/api/v1"
DATABASE_URL="sqlite:///./nethra_ai.db"  # Use postgresql://user:password@host:port/dbname for production
UPLOAD_DIR="uploads"

# Celery / Redis
CELERY_BROKER_URL="redis://localhost:6379/0"
CELERY_RESULT_BACKEND="redis://localhost:6379/0"

# OCR Settings
TESSERACT_CMD="tesseract"
PROCESSING_VERSION="v1.0"

# Threat Intelligence API Keys (Leave blank if not used)
VIRUSTOTAL_API_KEY=""
ABUSEIPDB_API_KEY=""
HIBP_API_KEY=""
WHOIS_API_KEY=""
GEOIP_API_KEY=""
MAXMIND_ACCOUNT_ID=""
GEOIP_DB_PATH=""
BLOCKCHAIN_API_KEY=""
GEMINI_API_KEY=""
